{
  "manifest_version": 3,
  "name": "AegisStream",
  "version": "0.4.0",
  "description": "Adaptive media and web-page acceleration with proactive prefetching and smoother navigation.",
  "permissions": [
    "storage",
    "webRequest",
    "tabs",
    "scripting",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "<all_urls>",
    "*://*.googlevideo.com/*",
    "*://*.youtube.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "youtube_accelerator_rules",
        "enabled": true,
        "path": "src/background/config/dnr-rules.json"
      },
      {
        "id": "aegis_defuse_rules",
        "enabled": false,
        "path": "src/background/config/dnr-defuse-rules.json"
      },
      {
        "id": "aegis_defuse_aggressive_rules",
        "enabled": false,
        "path": "src/background/config/dnr-defuse-aggressive-rules.json"
      }
    ]
  },
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://youtube.com/*",
        "*://*.youtube.com/*"
      ],
      "js": [
        "src/page/shared/youtube-ump-flags.js",
        "src/page/media/youtube/kill-ump.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/page/shared/execution-guard.js",
        "src/page/shared/manifest-mapper.js",
        "src/page/shared/site-policy.js",
        "src/page/shared/cache-response-headers.js",
        "src/page/shared/range-buffer.js",
        "src/page/shared/youtube-ump-flags.js",
        "src/page/bridge/core.js",
        "src/page/shared/media-cache-key-page.js",
        "src/page/shared/cache-registry.js",
        "src/page/smoother/shared.js",
        "src/page/smoother/circuit-breaker/timing.js",
        "src/page/smoother/circuit-breaker/asset-breaker.js",
        "src/page/prefetch/buffer-health-monitor.js",
        "src/page/prefetch/seek-predictor.js",
        "src/page/media/video-monitor.js",
        "src/page/bridge/extension-fetch-client.js",
        "src/page/prefetch/video.js",
        "src/page/bridge/message-bridge.js",
        "src/page/media/youtube/playlist.js",
        "src/page/media/youtube/cross-itag-predictor.js",
        "src/page/interceptors/fetch.js",
        "src/page/interceptors/xhr.js",
        "src/page/smoother/navigation/hover-prefetch.js",
        "src/page/smoother/navigation/viewport-preconnect.js",
        "src/page/smoother/install.js",
        "src/page/main.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/execution-guard.js",
        "src/content/relay.js",
        "src/content/smoother/asset-tracker.js"
      ],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "action": {
    "default_title": "AegisStream",
    "default_popup": "src/popup/popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/page/shared/execution-guard.js",
        "src/page/shared/manifest-mapper.js",
        "src/page/shared/site-policy.js",
        "src/page/shared/cache-response-headers.js",
        "src/page/shared/range-buffer.js",
        "src/page/shared/youtube-ump-flags.js",
        "src/page/main.js",
        "src/page/bridge/core.js",
        "src/page/shared/media-cache-key-page.js",
        "src/page/shared/cache-registry.js",
        "src/page/smoother/shared.js",
        "src/page/smoother/circuit-breaker/timing.js",
        "src/page/smoother/circuit-breaker/asset-breaker.js",
        "src/page/prefetch/buffer-health-monitor.js",
        "src/page/prefetch/seek-predictor.js",
        "src/page/media/video-monitor.js",
        "src/page/bridge/extension-fetch-client.js",
        "src/page/prefetch/video.js",
        "src/page/bridge/message-bridge.js",
        "src/page/media/youtube/playlist.js",
        "src/page/media/youtube/cross-itag-predictor.js",
        "src/page/interceptors/fetch.js",
        "src/page/interceptors/xhr.js",
        "src/page/smoother/navigation/hover-prefetch.js",
        "src/page/smoother/navigation/viewport-preconnect.js",
        "src/page/smoother/install.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
